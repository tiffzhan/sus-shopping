# file: .env.local.example
# Copy this to .env.local and fill in your values.

# Database (SQLite - no changes needed for local dev)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production-generate-with-openssl-rand-base64-32"

# eBay Browse API (optional — live search requires these)
# Get credentials at: https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=""
EBAY_CLIENT_SECRET=""

# Cron protection (set to any secret string)
CRON_SECRET="change-me-too"

# Email (stub — fill in to enable notifications)
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="noreply@sus.shopping"
